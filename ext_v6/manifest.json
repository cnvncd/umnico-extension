{
  "manifest_version": 3,
  "name": "UMNICO Lead Info Extension",
  "version": "1.2.2",
  "description": "Расширение для обработчиков",
  "icons": {
    "128": "icon.png"
  },
  "permissions": ["activeTab", "storage", "scripting", "clipboardWrite"],
  "host_permissions": [
    "https://umnico.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
